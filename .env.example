# Storyblok Management API credentials
# Get these from your Storyblok space settings

# Personal Access Token (Settings > Access Tokens)
STORYBLOK_PERSONAL_MANAGEMENT_TOKEN=your_token_here

# Your Storyblok space ID
# Find it in the URL: app.storyblok.com/f/[SPACE_ID]
# You can include the # prefix (it's automatically stripped)
STORYBLOK_SPACE_ID=your_space_id_here
